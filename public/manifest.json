{
  "name": "job post marker",
  "description": "A set of tools to help you mark job posts you've already applied/seen to.",
  "version": "0.0.0",
  "manifest_version": 3,
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "index.html",
    "default_icon": "vite.svg"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.onlinejobs.ph/*",
        "https://www.linkedin.com/jobs/*",
        "https://*.indeed.com/jobs*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
